{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    // "height": 30, // Waybar height (to be removed for auto height)
                  // "width": 1280, // Waybar width
        // "spacing": 0, // Gaps between modules (4px)
                      // Choose the order of the modules
        "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/media"],
        // "modules-center": ["sway/window"],
        // "modules-center": ["clock"],
        "modules-right": ["network", "pulseaudio", "battery", "clock", "tray"],
        // "network", "cpu", "memory", "temperature", "backlight", "keyboard-state", "sway/language", "mpd", "tray", "battery#bat2", 
        // UNUSED MODULES ^
        // Modules configuration
        "sway/workspaces": {
            "disable-scroll": true,
            "all-outputs": true,
            "format": "{icon}\t{value}",
            "format-icons": {
                "1": "пД°",
                "2": "пЕЬ",
                "3": "пЙ©",
                "4": "пБµ",
                "9": "пАБ",
                "urgent": "пБ™",
                "focused": "пЖТ",
                "default": "пДС"
             }
        },
        "keyboard-state": {
            "numlock": true,
            "capslock": true,
            "format": "{name} {icon}",
            "format-icons": {
                "locked": "пА£",
                "unlocked": "пВЬ"
            }
        },
        "sway/mode": {
            "format": "<span style=\"italic\">{}</span>"
        },
        "sway/scratchpad": {
            "format": "{icon} {count}",
            "show-empty": false,
            "format-icons": ["", "пЛТ"],
            "tooltip": true,
            "tooltip-format": "{app}: {title}"
        },
        "mpd": {
            "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вЄ®{songPosition}|{queueLength}вЄ© {volume}% пАБ",
            "format-disconnected": "Disconnected пАБ",
            "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пАБ",
            "unknown-tag": "N/A",
            "interval": 2,
            "consume-icons": {
                "on": "пГД "
            },
            "random-icons": {
                "off": "<span color=\"#f53c3c\">пБі</span> ",
                "on": "пБі "
            },
            "repeat-icons": {
                "on": "пАЮ "
            },
            "single-icons": {
                "on": "пАЮ1 "
            },
            "state-icons": {
                "paused": "пБМ",
                "playing": "пБЛ"
            },
            "tooltip-format": "MPD (connected)",
            "tooltip-format-disconnected": "MPD (disconnected)"
        },
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "пБЃ",
                "deactivated": "пБ∞"
            }
        },
        "tray": {
            "icon-size": 24,
            "spacing": 10
        },
        "clock": {
            // "timezone": "America/New_York",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "format-alt": "{:%Y-%m-%d}",
            "format": "{:%H:%M}"
        },
        "cpu": {
            "format": "{usage}% пЛЫ",
            "tooltip": false
        },
        "memory": {
            "format": "{}% пГЙ"
        },
        "temperature": {
            // "thermal-zone": 2,
            // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
            "critical-threshold": 80,
            // "format-critical": "{temperatureC}¬∞C {icon}",
            "format": "{temperatureC}¬∞C {icon}",
            "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"]
        },
        "backlight": {
            // "device": "acpi_video1",
            "format": "{percent}% {icon}",
            "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
        },
        "battery": {
            "states": {
                // "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}%",
            "format-plugged": "{capacity}% пЗ¶",
            "format-alt": "{time} {icon}",
            // "format-good": "", // An empty format will hide the module
            // "format-full": "",
            "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
        },
        "battery#bat2": {
            "bat": "BAT2"
        },
        "network": {
            // "interface": "wlp2*", // (Optional) To force the use of this interface
            "format-wifi": "пЗЂ   {essid}",
            "format-ethernet": "{ipaddr}/{cidr} пЮЦ",
            "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
            "format-linked": "{ifname} (No IP) пЮЦ",
            "format-disconnected": "Disconnected вЪ†",
            "format-alt": "{ifname}: {ipaddr}/{cidr}"
        },
        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon}",
            "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
            "format-bluetooth-muted": " {icon}пКФ {format_source}",
            "format-muted": "0% пА¶",
            "format-source": "{volume}% пД∞",
            "format-source-muted": "пД±",
            "format-icons": {
                "headphone": "пА•",
                "hands-free": "",
                "headset": "",
                "phone": "пВХ",
                "portable": "пВХ",
                "car": "пЖє",
                "default": ["пА¶", "пАІ", "пА®"]
            },
            "on-click": "pavucontrol"
        },
        "custom/media": {
            "format": "{icon} {}",
            "return-type": "json",
            "max-length": 40,
            "format-icons": {
                "spotify": "пЖЉ",
                "default": "рЯОЬ"
            },
            "escape": true,
            "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
                                                                       // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
        }
}

