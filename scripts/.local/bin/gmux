#!/bin/bash
# Simple script for setting up tmux sessions. Based on templates.
# Author: @lnus
#
# Usage: gmux <session-name> <session-type>
#
# Example: gmux my-session bare (will create a new session called my-session with a bare tmux setup)
# Example: gmux my-session nvim (will create a new session called my-session with a NeoVim setup)
#
# TODO: Add more types
# TODO: Add a way to add custom templates
# TODO: Rewrite this in Python or something if it gets too big

# Check if the session name is provided
if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Usage: gmux <session-name> <session-type>"
    echo "Available types: bare, nvim, mega"
    exit 1
fi

# Check if the session already exists
if tmux has-session -t "$1" 2>/dev/null; then
    echo "Session already exists"
    exit 1
fi

# Bare: Create a new session and attach to it
if [ "$2" == "bare" ]; then
    tmux new-session -s "$1" -n "main" -d
    tmux attach-session -t "$1:0"
    exit 0
fi

# Nvim: Create a new session, a new window, spawn NeoVim in the new window and split the pane
if [ "$2" == "nvim" ]; then
    tmux new-session -s "$1" -n "main" -d
    tmux send-keys -t "$1:0" "nvim $(pwd)" C-m
    tmux split-window -h -t "$1:0"
    tmux attach-session -t "$1:0"
    exit 0
fi

# Mega: Create a new session, and three split panes
if [ "$2" == "mega" ]; then
    tmux new-session -s "$1" -n "main" -d
    # tmux send-keys -t "$1:0" "nvim $(pwd)" C-m
    tmux split-window -h -t "$1:0"
    tmux split-window -v -t "$1:0.1"
    tmux attach-session -t "$1:0.0"
    exit 0
fi

# If the session type is not caught by any of the above, exit with an error
echo "Invalid session type"
echo "Available types: bare, nvim, mega"
exit 1
